# ============================================================
#  NyXia — Tokens & Configuration
#  Renomme ce fichier en .env et remplis tes valeurs
#  ⚠️  Ne JAMAIS committer .env sur GitHub !
# ============================================================

# ── GROQ (obligatoire) ──────────────────────────────────────
# → https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── GITHUB (un seul token pour tous tes repos) ─────────────
# → https://github.com/settings/tokens/new
# Permissions : repo (Read/Write Contents + Read metadata)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=ton_username_github

# ── CLOUDFLARE ──────────────────────────────────────────────
# Token → https://dash.cloudflare.com/profile/api-tokens
# Permissions : Workers Scripts Edit · Workers KV Edit · Pages Edit
CF_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Account ID → https://dash.cloudflare.com (colonne droite)
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PROJETS Cloudflare ──────────────────────────────────────
REPO_AFFILIATIONPRO=affiliationpro
CF_WORKER_AFFILIATIONPRO=affiliationpro-api
CF_PAGES_AFFILIATIONPRO=affiliationpro
CF_KV_AFFILIATIONPRO=

REPO_PUBLICATIONCASHFLOW=publicationcashflow
CF_WORKER_CASHFLOW=cashflow-api
CF_PAGES_CASHFLOW=publicationcashflow
CF_KV_CASHFLOW=

# ── SERVEUR ─────────────────────────────────────────────────
PORT=3000
