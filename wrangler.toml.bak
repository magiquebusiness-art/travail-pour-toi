name = "nyxia-agent-v2"
main = "index.js"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[vars]
VAULT_SECRET = "nyxia-v2-secret-key-2024"

[assets]
directory = "public"
binding = "ASSETS"
run_worker_first = true

[[kv_namespaces]]
binding = "NYXIA_VAULT"
id = "c62f5d8ca37e450bb8c9efba5263214c"

[ai]
binding = "AI"

[[d1_databases]]
binding = "DB_AFFILIATION"
database_name = "affiliation-pro-db"
database_id = "0b22a4ba-4d5f-404d-b2e0-4838de6b1822"
